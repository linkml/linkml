	sh:prefix "shex" .
_:c14n2 sh:namespace "http://schema.org/"^^xsd:anyURI ;
	sh:prefix "schema" .
_:c14n3 sh:namespace "https://w3id.org/linkml/"^^xsd:anyURI ;
	sh:prefix "linkml" .
